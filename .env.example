# Synod configuration.
# Copy to `.env` and fill in to run against live Qwen Cloud.
# Leave LLM_PROVIDER=mock to run fully offline with deterministic agents.

LLM_PROVIDER=mock                 # "mock" (offline, deterministic) | "qwen" (live)

# Qwen Cloud (DashScope). Only needed when LLM_PROVIDER=qwen.
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max        # judgment tier: Empathy read, Arbiter, baseline, adversary GM
QWEN_MODEL_FAST=qwen-turbo # volume tier: the 5 parallel lens scorings + challenge exchanges

# Receipt signing secret (HMAC). Any non-empty string works for the MVP.
SYNOD_SIGNING_SECRET=dev-only-not-secret

PORT=4173
